# Talos — environment template. Copy to .env.local and fill in the SECRET values.
# .env.local is gitignored and must NEVER be committed (it holds a real private key).
#
# Public values (on-chain object IDs, RPC, addresses) are safe to keep here as-is.
# Secret values (the agent key + LLM API keys) are blank — paste yours on the box only.

# --- Sui (MAINNET) ---
SUI_NETWORK=mainnet
SUI_RPC=https://fullnode.mainnet.sui.io:443
SUI_MAINNET_RPC=https://fullnode.mainnet.sui.io:443

# --- Talos on-chain objects (public; safe to commit) ---
TALOS_PACKAGE_ID=0x75b7f5d2926f333d8849726655904111420d4f86acb2578274b31338bcf8142c
TALOS_POLICY_ID=0x61b198ecfacb835b9078274e2c3de2f84ce8ea1d0dd9a99bf13afb65584fe9bf
TALOS_REPUTATION_ID=0xcadc34281fa4a2415b9b6ef94a498cb91bf9030fcbe080efc1136498f264a7a2
TALOS_OWNER_CAP=0x5b8980f3b50ef2c70aa11f3383ad7859e079eb527ac094aa86a0c6c429ecf6fa
TALOS_AGENT_ADDRESS=0x1f0455e5fb79711dff710e04aa9a7ea4dbb582b77a3a5452fcc61be1cb80ea7f

# --- SECRET: the agent's Sui private key (suiprivkey1...). Leave blank in git. ---
TALOS_AGENT_KEY=

# --- real lending leg (mainnet): real USDC moves across Scallop + NAVI + Kai ---
TALOS_LENDING=1
TALOS_SCALLOP=1
TALOS_USDC_CHUNK=0.1

# --- autonomous swarm (scripts/run-swarm.ts) ---
TALOS_START_PROTOCOL=navi
TALOS_INTERVAL_MS=30000

# --- LLM brain (Groq preferred — no aggressive rate limit). SECRET: leave blank in git. ---
# Preference order when set: Groq -> Mistral -> Claude. Force with TALOS_LLM_PROVIDER.
GROQ_API_KEY=
MISTRAL_API_KEY=
# TALOS_ANTHROPIC_API_KEY=
# TALOS_LLM_MODEL=openai/gpt-oss-120b
# TALOS_LLM_PROVIDER=groq

# --- Walrus (decision log / agent memory) ---
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# --- Managed wallet (custodial embedded wallet) ---
MONGODB_URI=                      # MongoDB Atlas connection string (server only)
WALLET_ENC_KEY=                   # 32-byte hex, AES-256-GCM key for private-key encryption
SESSION_SECRET=                   # random secret for the jose session JWT
WALLET_FUNDING_KEY=               # suiprivkey1... of the gas-drip funding wallet (SEPARATE from agent key)
GOOGLE_CLIENT_SECRET=             # Google OAuth web client secret (server only)
APP_URL=http://localhost:3000     # origin used to build the OAuth redirect URI
# WALLET_DRIP_SUI=0.05            # optional override
